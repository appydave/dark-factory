{
  "pattern": "unknown",
  "globs": {
    "context": ["CLAUDE.md", "CLAUDE.local.md", "context/CONTEXT.md"],
    "docs": ["docs/**/*.md", "README.md", "AUDIT-2026-06-12.md"],
    "north_star": ["docs/north-star.md", "docs/dark-factory-constellation.md", "docs/runtime-model.md", "docs/architecture.md"],
    "specs": ["docs/canonical-form-spec.md", "docs/provenance-spec.md", "docs/ingestion-workflow.md", "docs/dark-factory-living-system-spec.md", "docs/sop-lifecycle.md"],
    "watchtower_docs": ["docs/watchtower/**/*.md"],
    "skills": [".claude/skills/**/SKILL.md"],
    "workflows": [".claude/workflows/*.js"],
    "engine": ["experiments/watchtower-engine/**/*.md", "experiments/watchtower-engine/**/*.sh", "experiments/watchtower-engine/**/*.jsonl"],
    "experiments": ["experiments/**/*.md"],
    "planning": ["backlog/**/*.md"],
    "specs_store": ["backlog/specs/**/*.md"],
    "tools": ["tools/**/*.py", "tools/**/*.md", "tools/**/*.sh"],
    "canonical": ["canonical/**/*.md", "canonical/**/provenance.json"],
    "research": ["research/**/*.md"],
    "research_data": ["research/**/*.json", "research/**/*.jsonl"],
    "mockups": ["mochaccino/designs/**/*.html"],
    "mockup_data": ["mochaccino/data/*.json"],
    "spikes": ["spikes/**/*.md", "spikes/**/*.mjs"]
  },
  "aliases": {
    "orient": ["context", "north_star"],
    "build": ["skills", "workflows", "engine", "tools"],
    "library": ["canonical", "research", "research_data"],
    "platform": ["workflows", "engine", "experiments", "spikes"],
    "visual": ["mockups", "mockup_data"]
  },
  "composites": {
    "understand": ["context", "north_star", "docs"],
    "machinery": ["skills", "workflows", "engine", "tools", "watchtower_docs"],
    "cargo": ["canonical", "research", "research_data", "specs"],
    "full": ["*"]
  }
}
