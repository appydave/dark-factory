{
  "pattern": "unknown",
  "globs": {
    "docs": ["docs/**/*.md", "README.md"],
    "context": ["CLAUDE.md", "context/CONTEXT.md"],
    "canonical": ["canonical/**/*.md", "canonical/**/provenance.json"],
    "research": ["research/**/*.md"],
    "research_data": ["research/**/*.json", "research/**/*.jsonl"],
    "planning": ["backlog/**/*.md"],
    "experiments": ["experiments/**/*.md", "experiments/**/*.json"],
    "spikes": ["spikes/**/*.md", "spikes/**/*.mjs", "spikes/**/package.json"],
    "workflows": [".claude/workflows/*.js"],
    "watchtower": ["docs/watchtower/**/*.md", "experiments/watchtower-engine/**/*.md", "experiments/watchtower-engine/**/*.sh", "experiments/watchtower-engine/skills/**/SKILL.md"],
    "app": ["apps/**/*.ts", "apps/**/*.tsx", "apps/**/CLAUDE.md", "apps/**/README.md"],
    "mockups": ["mochaccino/designs/**/*.html"],
    "config": ["mochaccino/data/*.json"]
  },
  "aliases": {
    "specs": ["docs", "context"],
    "build": ["canonical", "planning"],
    "library": ["canonical", "research"],
    "platform": ["workflows", "spikes", "experiments", "watchtower"]
  },
  "composites": {
    "understand": ["context", "docs", "research"],
    "codebase": ["canonical", "research", "planning", "workflows", "app"],
    "full": ["*"]
  }
}
