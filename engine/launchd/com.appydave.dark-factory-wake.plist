<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.appydave.dark-factory-wake</string>
  <key>ProgramArguments</key><array>
    <string>/usr/bin/python3</string><string>__APP_ROOT__/engine/wake.py</string>
  </array>
  <key>WorkingDirectory</key><string>__APP_ROOT__</string>
  <key>WatchPaths</key><array>
    <string>__APP_ROOT__/engine/store/queue</string>
    <string>__APP_ROOT__/engine/store/done</string>
  </array>
  <key>ThrottleInterval</key><integer>10</integer>
  <key>StandardOutPath</key><string>__APP_ROOT__/engine/store/wake.log</string>
  <key>StandardErrorPath</key><string>__APP_ROOT__/engine/store/wake.log</string>
</dict></plist>
