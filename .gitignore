# macOS
.DS_Store

# Editor / IDE
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node
node_modules/

# Mochaccino server logs
mochaccino/.serve.log

# Git worktrees
.claude/worktrees/

# Claude Code runtime artifacts at .claude/ root (locks, logs) — never track.
# Targets root-level files only: settings.json and skills/ + workflows/ stay tracked.
.claude/*.lock
.claude/*.log

# JSONL backups
research/*.bak-*

# Claude Code local machine-specific overrides
CLAUDE.local.md
.context/

# Env / secrets
.env
.env.local
*.pem

# Transient tool working dirs (local cache / capture output — never track)
.mochaccino/
.playwright-mcp/
.serve.log

# Scratch render proofs / screenshots at repo root (real assets belong in a subfolder)
/*.png
